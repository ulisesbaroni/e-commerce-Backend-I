<h1>Productos en tiempo real</h1>

<ul id="lista-productos">
  {{#each products}}
    <li id="producto-{{this.id}}">
      <strong>{{this.title}}</strong> — ${{this.price}}
      <button onclick="eliminarProducto('{{this.id}}')">Eliminar</button>
    </li>
  {{/each}}
</ul>

<hr />

<h2>Agregar producto</h2>
<form id="form-producto">
  <input type="text" id="title" placeholder="Título" required /><br />
  <input type="text" id="description" placeholder="Descripción" required /><br />
  <input type="text" id="code" placeholder="Código" required /><br />
  <input type="number" id="price" placeholder="Precio" required /><br />
  <input type="number" id="stock" placeholder="Stock" required /><br />
  <input type="text" id="category" placeholder="Categoría" required /><br />
  <button type="submit">Crear producto</button>
</form>

<script src="/socket.io/socket.io.js"></script>
<script>
  const socket = io();

  // Actualiza la lista cuando el servidor emite cambios
  socket.on("productos-actualizados", (products) => {
    const lista = document.getElementById("lista-productos");
    lista.innerHTML = products.map((p) => `
      <li id="producto-${p.id}">
        <strong>${p.title}</strong> — $${p.price}
        <button onclick="eliminarProducto('${p.id}')">Eliminar</button>
      </li>
    `).join("");
  });

  // Enviar nuevo producto por socket
  document.getElementById("form-producto").addEventListener("submit", (e) => {
    e.preventDefault();

    const producto = {
      title: document.getElementById("title").value,
      description: document.getElementById("description").value,
      code: document.getElementById("code").value,
      price: Number(document.getElementById("price").value),
      stock: Number(document.getElementById("stock").value),
      category: document.getElementById("category").value,
    };

    socket.emit("crear-producto", producto);
    e.target.reset();
  });

  function eliminarProducto(id) {
    socket.emit("eliminar-producto", id);
  }
</script>