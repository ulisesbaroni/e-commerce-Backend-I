<div class="detalle-carrito">
  <h1>Mi carrito</h1>

  {{#if cart.products.length}}
    <ul class="lista-productos">
      {{#each cart.products}}
        <li>
          <strong>{{this.product.title}}</strong> — ${{this.product.price}} x {{this.quantity}}
        </li>
      {{/each}}
    </ul>
  {{else}}
    <p>El carrito está vacío.</p>
  {{/if}}

  <a href="/products">Seguir comprando</a>
</div>
